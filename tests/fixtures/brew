#!/bin/sh
# Fixture: pretends to be `brew`, answering `brew outdated` with canned JSON.
# Respects ZPUN_FIXTURE_BREW env var for alternate scenarios.
case "$1" in
  outdated)
    case "${ZPUN_FIXTURE_BREW:-default}" in
      empty)
        # Nothing outdated.
        if [ "$2" = "--json=v2" ] || [ "$2" = "--quiet" ]; then
          echo '{"formulae":[],"casks":[]}'
          exit 0
        fi
        exit 0
        ;;
      fail)
        echo "brew fixture: simulated failure" >&2
        exit 1
        ;;
      slow)
        sleep 30
        exit 0
        ;;
      *)
        # Two outdated formulae and one outdated cask.
        for arg in "$@"; do
          if [ "$arg" = "--json=v2" ]; then
            cat <<'JSON'
{"formulae":[
  {"name":"gh","installed_versions":["2.60.0"],"current_version":"2.62.0"},
  {"name":"fd","installed_versions":["10.1.0"],"current_version":"10.2.0"}
],"casks":[
  {"name":"example-app@latest","installed_versions":["0.9.0"],"current_version":"0.9.1"}
]}
JSON
            exit 0
          fi
        done
        # --quiet form: only emits names; formulae and casks are separate invocations.
        for arg in "$@"; do
          if [ "$arg" = "--cask" ]; then
            printf 'example-app@latest\n'
            exit 0
          fi
        done
        printf 'gh\nfd\n'
        exit 0
        ;;
    esac
    ;;
  upgrade)
    echo "brew fixture upgraded: $2"
    exit 0
    ;;
  info)
    # `brew info --json=v2 <name1> [<name2> ...]` for the min-age lookup
    # (single per-row OR batched prefetch). Returns one combined JSON
    # response with formulae[] and casks[] arrays, mirroring real brew.
    shift
    f_entries=""
    c_entries=""
    for arg in "$@"; do
      case "$arg" in
        --cask|--formula|--json=v2|--json) continue ;;
      esac
      first=$(printf '%s' "$arg" | cut -c1)
      case "$arg" in
        *@latest|blender|fxfactory|onyx|*-license-manager|*-product-manager|shutter-encoder)
          # Casks report `.name` as an array of display strings and `.token`
          # as the CLI identifier. We mirror that so .token matches the key
          # the lookup uses.
          [ -z "$c_entries" ] || c_entries="$c_entries,"
          c_entries="${c_entries}{\"name\":[\"$arg display\"],\"token\":\"$arg\",\"ruby_source_path\":\"Casks/$first/$arg.rb\"}"
          ;;
        *)
          [ -z "$f_entries" ] || f_entries="$f_entries,"
          f_entries="${f_entries}{\"name\":\"$arg\",\"ruby_source_path\":\"Formula/$first/$arg.rb\"}"
          ;;
      esac
    done
    printf '{"formulae":[%s],"casks":[%s]}\n' "$f_entries" "$c_entries"
    exit 0
    ;;
  *)
    exit 0
    ;;
esac
